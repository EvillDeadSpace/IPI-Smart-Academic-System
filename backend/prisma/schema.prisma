generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id                 Int                       @id @default(autoincrement())
  email              String                    @unique
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  currentYear        Int                       @default(1)
  dateOfBirth        DateTime
  firstName          String
  indexNumber        String                    @unique
  lastName           String
  majorId            Int
  password           String
  status             StudentStatus             @default(ACTIVE)
  comments           Comment[]
  documentRequests   DocumentRequest[]
  grades             Grade[]
  major              Major                     @relation(fields: [majorId], references: [id])
  examRegistrations  StudentExamRegistration[]
  subjectEnrollments SubjectEnrollment[]
  yearEnrollments    YearEnrollment[]

  @@index([majorId])
}

model Major {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  code        String     @unique
  description String?
  duration    Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  students    Student[]
  subjects    Subject[]
  yearPlans   YearPlan[]

  @@index([code])
}

model YearPlan {
  id       Int       @id @default(autoincrement())
  year     Int
  semester Int
  majorId  Int
  subjects Subject[]
  major    Major     @relation(fields: [majorId], references: [id])

  @@unique([majorId, year, semester])
  @@index([majorId])
}

model Subject {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  ects               Int
  isElective         Boolean             @default(false)
  description        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  yearPlanId         Int
  majorId            Int
  exams              Exam[]
  grades             Grade[]
  lectures           Lecture[]
  professors         ProfessorSubject[]
  homeworks          Homework[]
  major              Major               @relation(fields: [majorId], references: [id])
  yearPlan           YearPlan            @relation(fields: [yearPlanId], references: [id])
  subjectEnrollments SubjectEnrollment[]

  @@index([majorId])
  @@index([yearPlanId])
}

model YearEnrollment {
  id           Int      @id @default(autoincrement())
  academicYear String
  year         Int
  enrolledAt   DateTime @default(now())
  studentId    Int
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
  @@index([studentId])
}

model SubjectEnrollment {
  id           Int      @id @default(autoincrement())
  academicYear String
  semester     Int
  enrolledAt   DateTime @default(now())
  studentId    Int
  subjectId    Int
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, academicYear])
  @@index([studentId])
  @@index([subjectId])
}

model Grade {
  id           Int        @id @default(autoincrement())
  grade        Int
  examDate     DateTime
  examType     ExamType
  academicYear String
  points       Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  studentId    Int
  subjectId    Int
  professorId  Int?
  professor    Professor? @relation(fields: [professorId], references: [id])
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([subjectId])
  @@index([professorId])
}

model Exam {
  id            Int                       @id @default(autoincrement())
  subjectId     Int
  professorId   Int
  examTime      DateTime
  location      String?
  maxPoints     Int                       @default(100)
  createdAt     DateTime                  @default(now())
  professor     Professor                 @relation(fields: [professorId], references: [id], onDelete: Cascade)
  subject       Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  registrations StudentExamRegistration[]

  @@index([subjectId])
  @@index([professorId])
}

model StudentExamRegistration {
  id           Int      @id @default(autoincrement())
  studentId    Int
  examId       Int
  registeredAt DateTime @default(now())
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@index([studentId])
  @@index([examId])
}

model Professor {
  id        Int                @id @default(autoincrement())
  firstName String
  lastName  String
  email     String             @unique
  title     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  office    String?
  password  String
  exams     Exam[]
  grades    Grade[]
  lectures  Lecture[]
  subjects  ProfessorSubject[]
  homeworks Homework[]

  @@index([email])
}

model ProfessorSubject {
  id          Int       @id @default(autoincrement())
  professorId Int
  subjectId   Int
  assignedAt  DateTime  @default(now())
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([professorId, subjectId])
  @@index([professorId])
  @@index([subjectId])
}

model DocumentRequest {
  id              Int                   @id @default(autoincrement())
  documentType    DocumentType
  status          DocumentRequestStatus @default(PENDING)
  pdfUrl          String?
  requestDate     DateTime              @default(now())
  processedDate   DateTime?
  processedBy     String?
  rejectionReason String?
  studentData     Json?
  studentId       Int
  student         Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@index([requestDate])
}

model NewsInformation {
  id           Int       @id @default(autoincrement())
  tagName      String
  title        String
  likes        Int       @default(0)
  content      String
  linksParent  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  calendarNews Boolean   @default(false)
  eventDate    DateTime?
  online       Boolean   @default(true)
  comments     Comment[]
}

model Comment {
  id        String          @id @default(cuid())
  content   String
  userId    Int
  newsId    Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  news      NewsInformation @relation(fields: [newsId], references: [id], onDelete: Cascade)
  student   Student         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([newsId])
  @@index([createdAt])
}

model Lecture {
  id          Int       @id @default(autoincrement())
  dayOfWeek   Int
  startTime   String
  endOfTime   String
  room        String
  createAt    DateTime  @default(now())
  updateAt    DateTime  @updatedAt
  subjectId   Int
  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([professorId])
  @@index([dayOfWeek])
}

enum ExamType {
  REGULAR
  FIRST_RETRY
  SECOND_RETRY
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  EXPELLED
}

enum DocumentType {
  HEALTH_CERTIFICATE
  STATUS_CONFIRMATION
  TRANSCRIPT
  ENROLLMENT_CONFIRMATION
}

enum DocumentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Homework {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  s3Path      String
  dueDate     DateTime
  createdAt   DateTime  @default(now())
  subjectId   Int
  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  subject     Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([professorId])
  @@index([dueDate])
}
